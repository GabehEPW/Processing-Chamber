{
  "schemaVersion": 1,
  "id": "processing_chamber",
  "version": "${version}",
  "name": "Processing Chamber",
  "description": "Addon para Cobblemon usando Kotlin e Architectury.",
  "authors": ["GabehEPW"],
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
