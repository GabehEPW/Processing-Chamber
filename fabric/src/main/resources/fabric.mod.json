{
  "schemaVersion": 1,
  "id": "apricorn_chamber",
  "version": "${version}",
  "name": "Apricorn Chamber",
  "description": "Addon para Cobblemon usando Kotlin e Architectury.",
  "authors": ["GabehEPW"],
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.nbp.apricorn_chamber.fabric.ApricornChamberFabric"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.nbp.apricorn_chamber.fabric.ApricornChamberFabricClient"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.17.0",
    "minecraft": "1.21.1",
    "fabric-language-kotlin": "*",
    "cobblemon": "*"
  }
}
